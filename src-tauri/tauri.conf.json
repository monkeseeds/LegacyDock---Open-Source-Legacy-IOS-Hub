{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LegacyDock",
  "version": "0.1.0",
  "identifier": "com.legacydock.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix desktop run dev",
    "beforeBuildCommand": "npm --prefix desktop run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "LegacyDock",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost https://* http://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "copyright": "Copyright LegacyDock contributors",
    "category": "Utility",
    "icon": ["icons/icon.ico"],
    "shortDescription": "Legacy iOS diagnostics and repository hub.",
    "longDescription": "LegacyDock is a local-first desktop utility for preserving and maintaining legacy iOS devices.",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEQTZGRTU4MTZGOTMxRUMKUldUc01ma1dXUDZtN1k4RlNub2NoenZjbG5PQnZKWEFyUjRnMjJUaUJidFRaU1FPM2JuVlNtazgK",
      "endpoints": [
        "https://updates.legacydock.com/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
